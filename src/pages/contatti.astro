---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site.js';
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title={`Contatti — ${SITE.name}`}
  currentPath={`${base}contatti/`}
>
  <section class="hero hero-compact">
    <div class="container">
      <span class="hero-eyebrow">Contatti</span>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="kicker">Dove trovarci</span>
        <h2>Contatti & Orari</h2>
      </div>

      <div class="contact-grid">
        <div class="contact-item">
          <div class="contact-item-icon">📍</div>
          <div class="contact-item-label">Indirizzo</div>
          <div class="contact-item-value">{SITE.address}</div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon">📞</div>
          <div class="contact-item-label">Telefono</div>
          <div class="contact-item-value">
            <a href={`tel:${SITE.phone.replace(/\s/g,'')}`}>{SITE.phone}</a>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon">🕐</div>
          <div class="contact-item-label">Orari</div>
          <div class="contact-item-value">18:30 – 21:30</div>
          <div class="contact-item-note">Lun – Dom · Martedi chiuso</div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon">🛵</div>
          <div class="contact-item-label">Consegna</div>
          <div class="contact-item-value">Asporto & Delivery</div>
          <div class="contact-item-note">Mozzo €1 · Zone limitrofe €2</div>
        </div>
      </div>

      <div style="margin-top:2.5rem;border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-md);border:1px solid var(--slate-xlight);">
        <iframe
          src="https://www.openstreetmap.org/export/embed.html?bbox=9.6110%2C45.7135%2C9.6230%2C45.7200&layer=mapnik&marker=45.7167%2C9.6170"
          width="100%"
          height="350"
          style="border:0;display:block;"
          loading="lazy"
          title="Mappa L'Ulivo Pizzeria"
        ></iframe>
      </div>

      <div style="text-align:center;margin-top:1.5rem;">
        <a href="https://www.google.com/maps/search/?api=1&query=Via+Alfredo+Piatti+6+Mozzo+BG" target="_blank" rel="noopener" class="btn btn-primary">
          Apri in Google Maps
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
