---
import BaseLayout from '../layouts/BaseLayout.astro';
import { MENU, EXTRAS, DELIVERY } from '../data/menu.js';
import { SITE } from '../data/site.js';
const base = import.meta.env.BASE_URL;
const orderApi = SITE.ORDER_API || null;
const waNumber = SITE.WHATSAPP_NUMBER;

const sections = Object.entries(MENU);

// Build JSON for client-side
const menuDataJSON = JSON.stringify(
  sections.map(([key, sec]) => ({
    id: key,
    title: sec.title,
    items: sec.items.map(i => ({
      id: i.id,
      name: i.name,
      price: i.price,
      desc: i.desc || '',
      ingredients: (i.desc || '').split(/,\s*/).map(x => x.trim()).filter(Boolean),
    })),
  }))
);
---
<BaseLayout
  title={`Menu — ${SITE.name}`}
  description={`Il menu completo de L'Ulivo: pizze rosse, bianche, calzoni, panuozzi, fritti. Ordina online.`}
  currentPath={`${base}menu/`}
>
  <section class="hero hero-compact">
    <div class="container">
      <span class="hero-eyebrow">Menu & Ordina</span>
    </div>
  </section>

  <!-- Tabs -->
  <div class="menu-tabs-wrapper">
    <div class="container">
      <div class="menu-tabs" role="tablist" aria-label="Sezioni del menu">
        {sections.map(([key, sec], i) => (
          <button
            role="tab"
            class={`menu-tab ${i === 0 ? 'active' : ''}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-section={key}
          >
            {sec.icon} {sec.title}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Search -->
  <div class="menu-search-wrapper">
    <div class="container menu-container">
      <div class="menu-search-bar">
        <svg class="menu-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="search" id="menu-search" class="menu-search-input" placeholder="Cerca pizza, ingrediente..." aria-label="Cerca nel menu" autocomplete="off" />
        <button type="button" id="menu-search-clear" class="menu-search-clear" aria-label="Cancella" hidden>&times;</button>
      </div>
      <div id="menu-search-results" class="menu-search-results" hidden></div>
    </div>
  </div>

  <!-- Voice order button kept commented out for possible future reintroduction.
  <div id="voice-section" class="voice-section" style="display:none;">
    <div class="container menu-container">
      <button id="voice-btn" class="voice-btn" type="button" aria-label="Ordina a voce">
        <svg id="voice-mic" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="9" y="1" width="6" height="12" rx="3"/><path d="M5 10a7 7 0 0 0 14 0"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        <span id="voice-label">Ordina a voce</span>
      </button>
      <div id="voice-status" class="voice-status" hidden>
        <div class="voice-pulse"></div>
        <span id="voice-status-text">Sto ascoltando...</span>
      </div>
      <div id="voice-transcript" class="voice-transcript" hidden></div>
      <div id="voice-result" class="voice-result" hidden></div>
    </div>
  </div>
  -->

  <section class="section menu-section-wrap">
    <div class="container menu-container">

      <!-- Extras banner -->
      <div class="extras-banner">
        <h3>Extra & Consegna</h3>
        <p>🧀 {EXTRAS.cornicioneRicotta.name} — €{EXTRAS.cornicioneRicotta.price.toFixed(2)} ({EXTRAS.cornicioneRicotta.note})</p>
        <p>🛵 Mozzo €{DELIVERY.mozzo.price.toFixed(2)} · Zone limitrofe €{DELIVERY.limitrofi.price.toFixed(2)} · Pizza singola +€{DELIVERY.singola.price.toFixed(2)}</p>
      </div>

      <!-- Menu sections -->
      {sections.map(([key, sec], si) => (
        <div
          class={`menu-panel ${si === 0 ? 'active' : ''}`}
          data-section={key}
        >
          <div class="menu-section">
            <h2 class="menu-section-title">{sec.icon} {sec.title}</h2>
            {sec.items.map(item => (
              <div class="menu-card" data-item-id={item.id} data-item-name={item.name} data-item-price={item.price} data-item-desc={item.desc || ''}>
                <div class="menu-card-main">
                  <div class="menu-card-info">
                    <div class="menu-card-name">{item.name}</div>
                    {item.desc && <div class="menu-card-desc">{item.desc}</div>}
                  </div>
                  <div class="menu-card-right">
                    <div class="menu-card-price">{item.price.toFixed(2).replace('.',',')} &euro;</div>
                    <div class="menu-card-btns">
                      <button class="edit-btn" aria-label={`Personalizza ${item.name}`} data-id={item.id} title="Personalizza">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 11h2M3 8h4M3 5h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 4l-1 8H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </button>
                      <button class="add-btn" aria-label={`Aggiungi ${item.name}`} data-id={item.id} title="Aggiungi">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v8M6 10h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                      </button>
                    </div>
                  </div>
                </div>
                <!-- Expand panel for customization -->
                <div class="menu-card-expand">
                  <div class="expand-inner">
                    <div class="ingredient-chips"></div>
                    <div class="expand-input-row">
                      <input type="text" class="add-ingredient-input expand-input" placeholder="+ aggiungi ingrediente..." aria-label={`Aggiungi ingrediente a ${item.name}`} />
                    </div>
                    <div class="expand-input-row">
                      <input type="text" class="item-note-input expand-input expand-input-full" placeholder="Note (es. ben cotta, senza lattosio...)" aria-label={`Note per ${item.name}`} />
                    </div>
                    <div class="expand-actions">
                      <div class="qty-row">
                        <button class="qty-btn-new qty-dec" data-id={item.id} aria-label="Rimuovi">&#8722;</button>
                        <span class="qty-val" data-id={item.id}>1</span>
                        <button class="qty-btn-new qty-inc" data-id={item.id} aria-label="Aggiungi">+</button>
                      </div>
                      <button class="confirm-add-btn" data-id={item.id}>Aggiungi al carrello</button>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="menu-note">
        <strong>Nota:</strong> Per allergeni e intolleranze, contattare il personale al {SITE.phone}.
      </div>
    </div>
  </section>

  <!-- Persistent cart bar -->
  <div id="cart-bar" class="cart-bar" aria-hidden="true">
    <div class="cart-bar-inner">
      <div class="cart-bar-info">
        <span id="cart-bar-count" class="cart-bar-count">0</span>
        <span class="cart-bar-label">articoli</span>
        <span class="cart-bar-dot">&middot;</span>
        <strong id="cart-bar-total">0,00 &euro;</strong>
      </div>
      <button id="cart-bar-btn" class="cart-bar-btn" aria-label="Apri carrello">
        Vedi ordine
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>

  <!-- Closed banner (hidden by default) -->
  <div id="closed-banner" style="display:none;background:var(--red);color:white;text-align:center;padding:0.75rem 1rem;font-weight:700;font-size:0.85rem;position:sticky;top:56px;left:0;right:0;z-index:calc(var(--z-sticky) + 1);">
    <span id="closed-msg"></span>
  </div>

  <!-- Order mode modal -->
  <div id="order-mode-overlay" class="order-mode-overlay" aria-hidden="true"></div>
  <div id="order-mode-modal" class="order-mode-modal" role="dialog" aria-label="Modalita ordine" aria-hidden="true">
    <h3>Come vuoi ordinare?</h3>
    <p class="order-mode-sub">Seleziona data e modalita per il tuo ordine</p>
    <div class="order-mode-form" style="display:block;margin-bottom:1rem;">
      <label class="order-mode-label">Data</label>
      <input id="order-date" type="date" class="order-mode-input" style="border:2px solid var(--green-deep);border-bottom:2px solid var(--green-deep);padding:.5rem .75rem;" />
    </div>
    <div class="order-mode-options">
      <button id="mode-pickup-btn" class="order-mode-option">
        <span class="order-mode-icon">🏠</span>
        <span class="order-mode-title">Asporto</span>
        <span class="order-mode-desc">Ritiro in negozio</span>
      </button>
      <button id="mode-delivery-btn" class="order-mode-option">
        <span class="order-mode-icon">🛵</span>
        <span class="order-mode-title">Consegna</span>
        <span class="order-mode-desc">A domicilio</span>
      </button>
    </div>
    <!-- Pickup form -->
    <div id="mode-pickup-form" class="order-mode-form" style="display:none">
      <label class="order-mode-label">Nome</label>
      <input id="pickup-name" type="text" class="order-mode-input" placeholder="Il tuo nome" />
      <label class="order-mode-label">Orario ritiro</label>
      <div id="pickup-time-pills" class="delivery-time-pills" role="listbox">
        <div style="font-size:.85rem;color:var(--text-muted)">Caricamento orari...</div>
      </div>
      <button id="mode-pickup-confirm" class="order-mode-confirm" disabled>Conferma asporto</button>
    </div>
    <!-- Delivery form -->
    <div id="mode-delivery-form" class="order-mode-form" style="display:none">
      <label class="order-mode-label">Nome</label>
      <input id="delivery-name" type="text" class="order-mode-input" placeholder="Il tuo nome" />
      <label class="order-mode-label">Indirizzo</label>
      <input id="delivery-address" type="text" class="order-mode-input" placeholder="Via, numero civico, citta" />
      <label class="order-mode-label">Orario consegna</label>
      <input id="delivery-time" type="hidden" value="" />
      <div id="delivery-time-pills" class="delivery-time-pills" role="listbox">
        <div style="font-size:.85rem;color:var(--text-muted)">Caricamento orari...</div>
      </div>
      <button id="mode-delivery-confirm" class="order-mode-confirm" disabled>Conferma consegna</button>
    </div>
  </div>

  <!-- Cart drawer -->
  <div id="cart-overlay" class="cart-overlay" aria-hidden="true"></div>
  <div id="cart-drawer" class="cart-drawer" role="dialog" aria-label="Carrello" aria-hidden="true">
    <div class="cart-drawer-header">
      <h3>Il tuo ordine</h3>
      <button id="cart-close" class="cart-close" aria-label="Chiudi">&times;</button>
    </div>
    <div id="cart-items" class="cart-items">
      <div class="cart-empty">Nessun articolo nel carrello</div>
    </div>
    <div class="cart-footer">
      <div class="cart-notes-wrap">
        <label for="order-notes-global" class="cart-notes-label">Note generali:</label>
        <textarea id="order-notes-global" class="cart-notes-input" rows="2" placeholder="Allergie, richieste particolari..."></textarea>
      </div>
      <div class="cart-total">
        <span>Totale</span>
        <strong id="cart-total-price">0,00 &euro;</strong>
      </div>
      <button id="cart-send-btn" class="btn btn-send cart-send-btn" disabled>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Invia ordine via WhatsApp
      </button>
      <button id="cart-send-direct-btn" class="btn cart-send-direct-btn" disabled style="width:100%;margin-top:.5rem;padding:.6rem;background:var(--green-deep);color:white;border:2px solid var(--green-deep);font-family:var(--display);font-size:.85rem;font-weight:700;cursor:pointer;text-transform:uppercase;letter-spacing:.5px;opacity:.85">
        Invia ordine diretto (senza WhatsApp)
      </button>
    </div>
  </div>

  <!-- Direct order confirmation toast -->
  <div id="direct-order-toast" style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:white;border:3px solid var(--green-deep);box-shadow:8px 8px 0 var(--green-deep);padding:2rem;z-index:10000;max-width:90%;width:380px;text-align:center">
    <div style="font-family:var(--display);font-size:1.2rem;color:var(--green-deep);margin-bottom:.75rem;text-transform:uppercase;letter-spacing:1px">Ordine inviato!</div>
    <p style="font-size:.9rem;margin-bottom:1rem;color:var(--text)">Segui il tuo ordine:</p>
    <a id="direct-order-link" href="#" target="_blank" style="display:block;font-family:var(--display);font-size:1.1rem;color:var(--green-mid);letter-spacing:2px;word-break:break-all;margin-bottom:1rem"></a>
    <button onclick="document.getElementById('direct-order-toast').style.display='none';document.getElementById('direct-order-overlay').style.display='none'" style="padding:.5rem 1.5rem;background:var(--green-deep);color:white;border:2px solid var(--green-deep);font-family:var(--display);font-size:.9rem;cursor:pointer;text-transform:uppercase">Chiudi</button>
  </div>
  <div id="direct-order-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:9999"></div>

</BaseLayout>

<script define:vars={{ menuDataJSON, orderApi, waNumber }}>
  window.__MENU_DATA = menuDataJSON;
  window.__ORDER_API = orderApi;
  window.__WA_NUMBER = waNumber;
</script>

<script>
const ORDER_API: string | null = (window as any).__ORDER_API || null;
const WHATSAPP_NUMBER: string = (window as any).__WA_NUMBER || '393450908133';

interface ItemData { id: string; name: string; price: number; desc: string; ingredients: string[]; }
const MENU_DATA: Array<{id:string; title:string; items:ItemData[]}> = JSON.parse((window as any).__MENU_DATA || '[]');

const itemLookup = new Map<string, ItemData>();
MENU_DATA.forEach(s => s.items.forEach(i => itemLookup.set(i.id, i)));

// ---- State ----
interface CartEntry {
  id: string; baseItemId: string; name: string; desc: string; price: number; qty: number;
  removed: string[]; added: string[]; note: string;
}

let cart: CartEntry[] = [];
let orderMode: 'pickup' | 'delivery' | null = null;
let customerName: string = '';
let deliveryInfo: { name: string; address: string; time: string } | null = null;
let selectedDate: string = '';

function todayISO(): string {
  const d = new Date();
  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
}

// ---- Tab switching ----
const allTabs = document.querySelectorAll<HTMLElement>('.menu-tab');
const allPanels = document.querySelectorAll<HTMLElement>('.menu-panel');

allTabs.forEach(tab => {
  tab.addEventListener('click', () => {
    allTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
    tab.classList.add('active');
    tab.setAttribute('aria-selected', 'true');
    allPanels.forEach(p => p.classList.toggle('active', p.dataset.section === tab.dataset.section));

    // Scroll section title into view below sticky header/tabs/search
    const activePanel = document.querySelector('.menu-panel.active') as HTMLElement;
    if (activePanel) {
      const title = activePanel.querySelector('.menu-section-title') as HTMLElement;
      if (title) {
        const stickyOffset = 56 + 51 + 52 + 10; // header + tabs + search + gap
        const y = title.getBoundingClientRect().top + window.scrollY - stickyOffset;
        window.scrollTo({ top: y, behavior: 'smooth' });
      }
    }
  });
});

// ---- Menu card expand & cart ----
document.querySelectorAll<HTMLElement>('.menu-card').forEach(card => {
  const expandPanel = card.querySelector('.menu-card-expand') as HTMLElement;
  const addBtn = card.querySelector('.add-btn') as HTMLElement;
  const itemId = card.dataset.itemId!;
  const itemData = itemLookup.get(itemId);
  let tempQty = 1;
  let tempRemoved: Set<string> = new Set();
  let tempAdded: string[] = [];

  function renderChips() {
    const container = expandPanel.querySelector('.ingredient-chips')!;
    container.innerHTML = '';
    (itemData?.ingredients || []).forEach(ing => {
      const chip = document.createElement('span');
      chip.className = 'ing-chip' + (tempRemoved.has(ing) ? ' removed' : '');
      chip.innerHTML = `${ing} <span class="chip-x">${tempRemoved.has(ing) ? '+' : '\u00D7'}</span>`;
      chip.addEventListener('click', () => {
        if (tempRemoved.has(ing)) tempRemoved.delete(ing); else tempRemoved.add(ing);
        renderChips();
      });
      container.appendChild(chip);
    });
    tempAdded.forEach((ing, idx) => {
      const chip = document.createElement('span');
      chip.className = 'ing-chip added';
      chip.innerHTML = `+ ${ing} <span class="chip-x">\u00D7</span>`;
      chip.addEventListener('click', () => { tempAdded.splice(idx, 1); renderChips(); });
      container.appendChild(chip);
    });
  }

  function closeAllExpands() {
    document.querySelectorAll('.menu-card-expand.open').forEach(p => p.classList.remove('open'));
    document.querySelectorAll('.menu-card.expanding').forEach(c => c.classList.remove('expanding'));
  }

  function openExpand() {
    closeAllExpands();
    tempQty = 1; tempRemoved = new Set(); tempAdded = [];
    expandPanel.classList.add('open');
    card.classList.add('expanding');
    renderChips();
    const qtyEl = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement;
    if (qtyEl) qtyEl.textContent = '1';
    const noteInput = expandPanel.querySelector('.item-note-input') as HTMLInputElement;
    if (noteInput) noteInput.value = '';
    const addInput = expandPanel.querySelector('.add-ingredient-input') as HTMLInputElement;
    if (addInput) addInput.value = '';
    requestAnimationFrame(() => {
      setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 150);
    });
  }

  // Quick add
  addBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const entry: CartEntry = {
      id: itemId + '_' + Date.now(),
      baseItemId: itemId,
      name: itemData?.name || itemId,
      desc: itemData?.desc || '',
      price: itemData?.price || 0,
      qty: 1, removed: [], added: [], note: '',
    };
    if (cart.length === 0 && !orderMode) {
      pendingEntry = entry; pendingCard = card; pendingExpandPanel = expandPanel;
      showOrderModeModal();
      return;
    }
    cart.push(entry);
    card.classList.add('in-cart');
    card.animate([{transform:'scale(0.97)'},{transform:'scale(1)'}], {duration:200, easing:'ease-out'});
    updateCartUI();
  });

  // Edit button
  card.querySelector('.edit-btn')?.addEventListener('click', (e) => { e.stopPropagation(); openExpand(); });
  card.querySelector('.menu-card-info')?.addEventListener('click', () => openExpand());

  // Add ingredient input
  const addIngInput = expandPanel.querySelector('.add-ingredient-input') as HTMLInputElement;
  addIngInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && addIngInput.value.trim()) {
      e.preventDefault();
      tempAdded.push(addIngInput.value.trim());
      addIngInput.value = '';
      renderChips();
    }
  });

  // Qty controls
  expandPanel.querySelector('.qty-dec')?.addEventListener('click', () => {
    if (tempQty > 1) { tempQty--; const el = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement; if (el) el.textContent = String(tempQty); }
  });
  expandPanel.querySelector('.qty-inc')?.addEventListener('click', () => {
    tempQty++; const el = expandPanel.querySelector(`.qty-val[data-id="${itemId}"]`) as HTMLElement; if (el) el.textContent = String(tempQty);
  });

  // Confirm add — split qty>1 into individual entries for per-pizza editing
  expandPanel.querySelector('.confirm-add-btn')?.addEventListener('click', () => {
    const noteInput = expandPanel.querySelector('.item-note-input') as HTMLInputElement;
    const removedArr = Array.from(tempRemoved);
    const addedArr = [...tempAdded];
    const noteVal = noteInput?.value?.trim() || '';

    const entries: CartEntry[] = [];
    for (let i = 0; i < tempQty; i++) {
      entries.push({
        id: itemId + '_' + Date.now() + '_' + i,
        baseItemId: itemId,
        name: itemData?.name || itemId,
        desc: itemData?.desc || '',
        price: itemData?.price || 0,
        qty: 1,
        removed: [...removedArr],
        added: [...addedArr],
        note: noteVal,
      });
    }

    if (cart.length === 0 && !orderMode) {
      // Store first entry as pending, add rest after mode selection
      pendingEntry = entries[0];
      (window as any).__pendingExtras = entries.slice(1);
      pendingCard = card; pendingExpandPanel = expandPanel;
      showOrderModeModal();
      return;
    }
    entries.forEach(e => cart.push(e));
    expandPanel.classList.remove('open');
    card.classList.remove('expanding');
    card.classList.add('in-cart');
    card.animate([{transform:'scale(0.97)'},{transform:'scale(1)'}], {duration:200, easing:'ease-out'});
    updateCartUI();
  });
});

// ---- Pending entry ----
let pendingEntry: CartEntry | null = null;
let pendingCard: HTMLElement | null = null;
let pendingExpandPanel: HTMLElement | null = null;

// ---- Cart UI ----
const cartBar = document.getElementById('cart-bar')!;
const cartBarCount = document.getElementById('cart-bar-count')!;
const cartBarTotal = document.getElementById('cart-bar-total')!;
const cartDrawer = document.getElementById('cart-drawer')!;
const cartOverlay = document.getElementById('cart-overlay')!;
const cartItemsEl = document.getElementById('cart-items')!;
const cartTotalPrice = document.getElementById('cart-total-price')!;
const cartSendBtn = document.getElementById('cart-send-btn') as HTMLButtonElement;
const cartSendDirectBtn = document.getElementById('cart-send-direct-btn') as HTMLButtonElement;

function formatPrice(n: number): string { return n.toFixed(2).replace('.', ',') + ' \u20AC'; }
function totalQty(): number { return cart.reduce((s, e) => s + e.qty, 0); }
function totalPrice(): number { return cart.reduce((s, e) => s + e.price * e.qty, 0); }

function updateCartUI() {
  const count = totalQty();
  if (count > 0) {
    cartBar.classList.add('visible');
    cartBar.setAttribute('aria-hidden', 'false');
    cartBarCount.textContent = String(count);
    cartBarTotal.textContent = formatPrice(totalPrice());
  } else {
    cartBar.classList.remove('visible');
    cartBar.setAttribute('aria-hidden', 'true');
  }

  if (cart.length === 0) {
    cartItemsEl.innerHTML = '<div class="cart-empty">Nessun articolo nel carrello</div>';
  } else {
    cartItemsEl.innerHTML = cart.map((entry, idx) => {
      let modsHtml = '';
      if (entry.removed.length) modsHtml += entry.removed.map(r => `<span class="mod-remove">senza ${r}</span>`).join(', ');
      if (entry.added.length) modsHtml += (modsHtml ? ', ' : '') + entry.added.map(a => `<span class="mod-add">+ ${a}</span>`).join(', ');
      return `<div class="cart-item" data-idx="${idx}">
        <div class="cart-item-info">
          <div class="cart-item-name">${entry.name}</div>
          ${modsHtml ? `<div class="cart-item-mods">${modsHtml}</div>` : ''}
          ${entry.note ? `<div class="cart-item-note">"${entry.note}"</div>` : ''}
        </div>
        <div class="cart-item-actions">
          <div class="cart-item-price">${formatPrice(entry.price * entry.qty)}</div>
          <div class="cart-item-qty">
            <button class="cart-edit-btn" data-idx="${idx}" aria-label="Modifica" title="Modifica" style="border-color:var(--green-mid);color:var(--green-mid)">✏️</button>
            <button class="cart-remove-btn" data-idx="${idx}" aria-label="Rimuovi">\u{1F5D1}</button>
            <button data-action="dec" data-idx="${idx}">−</button>
            <span>${entry.qty}</span>
            <button data-action="inc" data-idx="${idx}">+</button>
          </div>
        </div>
      </div>`;
    }).join('');

    cartItemsEl.querySelectorAll('[data-action="dec"]').forEach(btn => {
      btn.addEventListener('click', () => { const i = parseInt((btn as HTMLElement).dataset.idx!); if (cart[i].qty > 1) cart[i].qty--; else cart.splice(i,1); updateCartUI(); });
    });
    cartItemsEl.querySelectorAll('[data-action="inc"]').forEach(btn => {
      btn.addEventListener('click', () => { cart[parseInt((btn as HTMLElement).dataset.idx!)].qty++; updateCartUI(); });
    });
    cartItemsEl.querySelectorAll('.cart-remove-btn').forEach(btn => {
      btn.addEventListener('click', () => { cart.splice(parseInt((btn as HTMLElement).dataset.idx!),1); updateCartUI(); });
    });
    // Edit: close cart, scroll to the menu card, open its expand panel
    cartItemsEl.querySelectorAll('.cart-edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.idx!);
        const entry = cart[idx];
        if (!entry) return;
        const baseId = entry.baseItemId || entry.id.split('_')[0];
        // Remove this item from cart (user will re-add after editing)
        cart.splice(idx, 1);
        updateCartUI();
        closeCart();
        // Find and open the menu card's expand panel
        const card = document.querySelector(`.menu-card[data-item-id="${baseId}"]`) as HTMLElement;
        if (card) {
          const editBtn = card.querySelector('.edit-btn') as HTMLElement;
          if (editBtn) editBtn.click();
          setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'center' }), 200);
        }
      });
    });
  }

  cartTotalPrice.textContent = formatPrice(totalPrice());
  cartSendBtn.disabled = cart.length === 0 || !orderMode;
  cartSendDirectBtn.disabled = cart.length === 0 || !orderMode;

  document.querySelectorAll<HTMLElement>('.menu-card').forEach(c => {
    const id = c.dataset.itemId!;
    c.classList.toggle('in-cart', cart.some(e => e.id.startsWith(id + '_')));
  });
}

// Cart open/close
function openCart() {
  cartOverlay.classList.add('open');
  cartDrawer.classList.add('open');
  document.body.classList.add('scroll-locked');
}
function closeCart() {
  cartOverlay.classList.remove('open');
  cartDrawer.classList.remove('open');
  document.body.classList.remove('scroll-locked');
}

document.getElementById('cart-bar-btn')?.addEventListener('click', openCart);
document.getElementById('cart-close')?.addEventListener('click', closeCart);
cartOverlay.addEventListener('click', closeCart);
document.addEventListener('keydown', e => { if (e.key === 'Escape' && cartDrawer.classList.contains('open')) closeCart(); });

// ---- Send Order ----
cartSendBtn.addEventListener('click', async () => {
  if (cart.length === 0 || !orderMode) return;

  const globalNotes = (document.getElementById('order-notes-global') as HTMLTextAreaElement)?.value?.trim();
  const name = orderMode === 'delivery' && deliveryInfo ? deliveryInfo.name : customerName;
  const ts = new Date().toLocaleString('it-IT', { dateStyle: 'short', timeStyle: 'short' });

  // Build WhatsApp message
  let header = '';
  if (orderMode === 'delivery' && deliveryInfo) {
    const dateLabel = selectedDate && selectedDate !== todayISO() ? selectedDate : 'Oggi';
    header = `*ORDINE — Consegna*\nNome: ${deliveryInfo.name}\nIndirizzo: ${deliveryInfo.address}\nOrario: ${deliveryInfo.time || 'Prima possibile'}\nData: ${dateLabel} (${ts})`;
  } else {
    const dateLabel = selectedDate && selectedDate !== todayISO() ? selectedDate : 'Oggi';
    header = `*ORDINE — Asporto*\nNome: ${name}\nRitiro: ${selectedPickupTime || 'Prima possibile'}\nData: ${dateLabel} (${ts})`;
  }

  let msg = `${header}\n\n*Articoli:*\n`;
  cart.forEach(entry => {
    msg += `\u2022 ${entry.name} x${entry.qty} \u2014 ${formatPrice(entry.price * entry.qty)}`;
    const mods: string[] = [];
    if (entry.removed.length) mods.push('SENZA: ' + entry.removed.join(', '));
    if (entry.added.length) mods.push('CON: ' + entry.added.join(', '));
    if (mods.length) msg += `\n  _${mods.join(' | ')}_`;
    if (entry.note) msg += `\n  _Nota: ${entry.note}_`;
    msg += '\n';
  });
  msg += `\n*TOTALE: ${formatPrice(totalPrice())}*`;
  if (globalNotes) msg += `\n\n*Note:* ${globalNotes}`;

  // Log order to backend and get tracking_id
  let trackingId = '';
  if (ORDER_API) {
    try {
      cartSendBtn.disabled = true;
      cartSendBtn.textContent = 'Invio in corso...';
      const resp = await fetch(`${ORDER_API}/api/orders`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          customerName: name || 'Anonimo',
          orderMode,
          deliveryAddress: deliveryInfo?.address || '',
          requestedTime: orderMode === 'delivery' ? (deliveryInfo?.time || '') : selectedPickupTime,
          requestedDate: selectedDate || todayISO(),
          items: cart.map(e => ({ name: e.name, desc: e.desc, qty: e.qty, price: e.price, removed: e.removed, added: e.added, note: e.note || '' })),
          totalPrice: totalPrice(),
          notes: globalNotes || '',
        }),
      });
      if (resp.ok) {
        const data = await resp.json();
        trackingId = data.tracking_id || '';
      }
    } catch {}

    // Store order in localStorage for "I miei ordini" history
    if (trackingId) {
      try {
        const myOrders = JSON.parse(localStorage.getItem('myOrders') || '[]');
        myOrders.unshift({ trackingId, date: new Date().toISOString(), total: totalPrice() });
        localStorage.setItem('myOrders', JSON.stringify(myOrders.slice(0, 50)));
      } catch {}
    }

    cartSendBtn.disabled = false;
    cartSendBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg> Invia ordine via WhatsApp';
  }

  // Append tracking link if available
  if (trackingId && ORDER_API) {
    msg += `\n\n\uD83D\uDCE6 *Segui il tuo ordine:*\n${ORDER_API}/track?id=${trackingId}`;
  }

  const waUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`;

  // Open WhatsApp
  const a = document.createElement('a');
  a.href = waUrl;
  a.target = '_blank';
  a.rel = 'noopener noreferrer';
  a.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
  document.body.appendChild(a);
  a.click();
  setTimeout(() => a.remove(), 200);

  // Reset cart
  cart.length = 0;
  updateCartUI();
  closeCart();
});

// ---- Direct order submit (no WhatsApp) ----
cartSendDirectBtn.addEventListener('click', async () => {
  if (cart.length === 0 || !orderMode) return;
  const name = orderMode === 'delivery' && deliveryInfo ? deliveryInfo.name : customerName;
  if (!name?.trim()) {
    alert('Il nome è obbligatorio per l\'ordine diretto');
    return;
  }
  const globalNotes = (document.getElementById('order-notes-global') as HTMLTextAreaElement)?.value?.trim();

  if (!ORDER_API) { alert('Server ordini non configurato'); return; }

  cartSendDirectBtn.disabled = true;
  cartSendDirectBtn.textContent = 'Invio in corso...';

  try {
    const resp = await fetch(`${ORDER_API}/api/orders`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        customerName: name,
        orderMode,
        deliveryAddress: deliveryInfo?.address || '',
        requestedTime: orderMode === 'delivery' ? (deliveryInfo?.time || '') : selectedPickupTime,
        requestedDate: selectedDate || todayISO(),
        items: cart.map(e => ({ name: e.name, desc: e.desc, qty: e.qty, price: e.price, removed: e.removed, added: e.added, note: e.note || '' })),
        totalPrice: totalPrice(),
        notes: globalNotes || '',
      }),
    });
    if (resp.ok) {
      const data = await resp.json();
      const trackingId = data.tracking_id || '';
      // Store in localStorage
      if (trackingId) {
        try {
          const myOrders = JSON.parse(localStorage.getItem('myOrders') || '[]');
          myOrders.unshift({ trackingId, date: new Date().toISOString(), total: totalPrice() });
          localStorage.setItem('myOrders', JSON.stringify(myOrders.slice(0, 50)));
        } catch {}
      }
      // Show confirmation toast
      const trackUrl = `${ORDER_API}/track?id=${trackingId}`;
      const linkEl = document.getElementById('direct-order-link') as HTMLAnchorElement;
      linkEl.href = trackUrl;
      linkEl.textContent = trackingId;
      document.getElementById('direct-order-overlay')!.style.display = 'block';
      document.getElementById('direct-order-toast')!.style.display = 'block';
      // Reset
      cart.length = 0;
      updateCartUI();
      closeCart();
    } else {
      alert('Errore nell\'invio dell\'ordine');
    }
  } catch {
    alert('Errore di connessione');
  }

  cartSendDirectBtn.disabled = false;
  cartSendDirectBtn.textContent = 'Invia ordine diretto (senza WhatsApp)';
});

// ---- Slot data ----
let slotsData: any = null;

// fetchSlots is now fetchSlotsForDate(date) — defined below

function renderTimePills(container: HTMLElement, onSelect: (time: string) => void) {
  container.innerHTML = '';
  if (!slotsData || slotsData.closed) {
    container.innerHTML = '<div style="font-size:.85rem;color:var(--error)">Chiuso oggi</div>';
    return;
  }
  // Group slots into 15-min display intervals
  const displaySlots: Array<{time: string; available: number; past: boolean}> = [];
  const seen = new Set<string>();
  (slotsData.slots || []).forEach((s: any) => {
    // Round to nearest 15 min for display
    const [h, m] = s.time.split(':').map(Number);
    const rounded = Math.floor(m / 15) * 15;
    const key = `${String(h).padStart(2,'0')}:${String(rounded).padStart(2,'0')}`;
    if (!seen.has(key)) {
      seen.add(key);
      // Sum availability for all 5-min slots in this 15-min window
      const windowSlots = (slotsData.slots || []).filter((ws: any) => {
        const [wh, wm] = ws.time.split(':').map(Number);
        return wh === h && wm >= rounded && wm < rounded + 15;
      });
      const totalAvail = windowSlots.reduce((s: number, ws: any) => s + ws.available, 0);
      const allPast = windowSlots.every((ws: any) => ws.past);
      displaySlots.push({ time: key, available: totalAvail, past: allPast });
    }
  });

  if (!displaySlots.length) {
    container.innerHTML = '<div style="font-size:.85rem;color:var(--text-muted)">Nessun orario disponibile</div>';
    return;
  }

  displaySlots.forEach(s => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'delivery-time-pill';
    if (s.past || s.available <= 0) {
      btn.disabled = true;
      btn.style.opacity = '0.35';
      btn.style.cursor = 'not-allowed';
    }
    const label = s.available <= 0 ? `${s.time} (pieno)` : s.past ? `${s.time} (passato)` : s.time;
    btn.textContent = label;
    btn.dataset.time = s.time;
    if (!s.past && s.available > 0) {
      btn.addEventListener('click', () => {
        container.querySelectorAll('.delivery-time-pill').forEach(b => (b as HTMLElement).classList.remove('selected'));
        btn.classList.add('selected');
        onSelect(s.time);
      });
    }
    container.appendChild(btn);
  });
}

// ---- Opening hours check ----
function checkIfOpen() {
  const now = new Date();
  const day = now.getDay();
  const banner = document.getElementById('closed-banner')!;
  const msg = document.getElementById('closed-msg')!;

  if (day === 2) { // Tuesday
    banner.style.display = 'block';
    msg.textContent = 'Martedì chiuso — gli ordini saranno per il prossimo giorno di apertura';
    return;
  }
  const h = now.getHours(), m = now.getMinutes();
  const nowMin = h * 60 + m;
  const openMin = 18 * 60 + 30;
  const closeMin = 21 * 60 + 30;
  if (nowMin < openMin) {
    banner.style.display = 'block';
    msg.textContent = `Apriamo alle 18:30 — puoi già comporre il tuo ordine!`;
  } else if (nowMin >= closeMin) {
    banner.style.display = 'block';
    msg.textContent = `Siamo chiusi — riapertura domani alle 18:30`;
  }
}
checkIfOpen();

