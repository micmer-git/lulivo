---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site.js';
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title={`${SITE.name} — ${SITE.tagline}`}
  currentPath={`${base}`}
  bodyClass="home-onepager"
>
  <section class="hero hero-full home-hero" aria-labelledby="hero-heading">
    <div class="hero-center-mark" aria-hidden="true">
      <span class="hero-script">L'Ulivo</span>
      <span class="hero-subline">Pizzeria d'Asporto</span>
    </div>

    <a class="hero-badge badge-menu" href={`${base}menu/`} aria-label="Vai al menu">
      <svg class="circle-text" viewBox="0 0 120 120" aria-hidden="true">
        <defs><path id="menu-circle" d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0" /></defs>
        <text><textPath href="#menu-circle">• MENU & ORDINA • MENU & ORDINA •</textPath></text>
      </svg>
      <span class="circle-center-label">Menu</span>
    </a>

    <a class="hero-badge badge-phone" href={`tel:${SITE.phone.replace(/\s/g,'')}`} aria-label="Chiama">
      <svg class="circle-text" viewBox="0 0 120 120" aria-hidden="true">
        <defs><path id="phone-circle" d="M60,60 m-44,0 a44,44 0 1,1 88,0 a44,44 0 1,1 -88,0" /></defs>
        <text><textPath href="#phone-circle">• CHIAMA ORA • CHIAMA ORA • CHIAMA •</textPath></text>
      </svg>
      <span class="circle-center-label">Chiama</span>
    </a>

    <div class="container">
      <h1 id="hero-heading" class="hero-title-hidden">{SITE.name}</h1>
    </div>
  </section>

  <div class="info-strip">
    <div class="container">
      <div class="grid">
        <div>
          <div class="item-label">Orari</div>
          <div class="item-value">{SITE.hours}</div>
        </div>
        <div>
          <div class="item-label">Telefono</div>
          <div class="item-value">{SITE.phone}</div>
        </div>
        <div>
          <div class="item-label">Indirizzo</div>
          <div class="item-value">Via A. Piatti, 6 — Mozzo</div>
        </div>
      </div>
    </div>
  </div>

  <section class="instagram-section">
    <a class="instagram-cta" href="https://www.instagram.com/lulivopizzeria/" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      Seguici su Instagram
    </a>
  </section>
</BaseLayout>
